# ---- SIRA Software Robot configuration ------------------------
# Base URL of the running SIRA Next.js app (the robot talks to its worker API).
SIRA_BASE_URL="http://localhost:3000"

# Shared worker secret. MUST match WORKER_WEBHOOK_SECRET in the SIRA app .env.
# Used both to claim/fetch jobs (x-sira-worker-secret header) and to sign the
# HMAC-SHA256 result callback (x-sira-worker-signature header).
WORKER_WEBHOOK_SECRET=""

# Run the browser with a visible window (true) or headless (false).
ROBOT_HEADFUL="false"

# Polling interval (seconds) when running in --loop mode.
ROBOT_POLL_INTERVAL="10"

# Optional: only claim jobs for this portal id (e.g. ethiopian_lmis, tawtheeq_musaned).
ROBOT_PORTAL=""

# Where to store confirmation screenshots.
ROBOT_SCREENSHOT_DIR="./screenshots"
