# ---- PostgreSQL (Neon) ----------------------------------------
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# ---- Auth.js / NextAuth v5 ------------------------------------
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Cloudinary (File Uploads) --------------------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ---- OCR -------------------------------------------------------
OCR_PROVIDER="google" # google | ocrspace
OCR_SPACE_API_KEY="your-ocrspace-api-key"
GOOGLE_VISION_API_KEY="your-google-vision-api-key"
GOOGLE_VISION_CREDENTIALS_JSON="{\"type\": \"service_account\", ...}"

# ---- LLM: Groq ------------------------------------------------
GROQ_API_KEY="gsk_your_groq_api_key_placeholder"

# ---- Image: remove.bg -----------------------------------------
REMOVE_BG_API_KEY="your-remove-bg-api-key"

# ---- Job Queue: Upstash QStash -------------------------------
QSTASH_URL="https://qstash-us-east-1.upstash.io"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"
WORKER_URL="http://localhost:3000/api/workers/webhook"

# ---- Email: SMTP ----------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="your-email@gmail.com"

# ---- AES-256-GCM Credential Encryption ------------------------
CREDENTIALS_ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# ---- Internal Worker Webhook HMAC Secret ----------------------
WORKER_WEBHOOK_SECRET="your-worker-webhook-secret-hmac"

# ---- Portal URLs ----------------------------------------------
LMIS_BASE_URL="https://lmis.gov.et"
EASYENJAZ_URL="https://www.easyenjaz.net/"
MOFA_URL="https://visa.mofa.gov.sa/"
WAFID_URL="https://wafid.com/en/medical-status-search/"
TASHEER_URL="https://vc.tasheer.com/home"
TAWTHEEQ_MUSANED_URL="https://tawtheeq.musaned.com.sa/"
JORDAN_MOI_URL="https://eservices.moi.gov.jo/"

# ---- App URL ---------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Portal Service (sira-portals on Render) -------------------
PORTAL_API_SECRET="your-portal-api-secret-matching-render"
PORTAL_SERVICE_URL="http://localhost:4000"
NEXT_PUBLIC_PORTAL_SERVICE_URL="http://localhost:4000"

# ---- Admin codes page credentials -------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="sira-admin-secure-2026"
