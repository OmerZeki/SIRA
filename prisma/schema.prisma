// prisma/schema.prisma — SIRA Production Schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum ApplicantStatus {
  REGISTERED
  MEDICAL_APPROVED
  LMIS_CLEAR
  MUSANED_CONTRACTED
  ENJAZ_COMPLETED
  FLIGHT_READY
  ON_HOLD
  REJECTED
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum LanguageLevel {
  NONE
  BASIC
  GOOD
  FLUENT
}

enum EducationLevel {
  NONE
  PRIMARY
  SECONDARY
  DIPLOMA
  DEGREE
  POSTGRADUATE
}

enum UserRole {
  OWNER
  MANAGER
  AGENT
  VIEWER
}

enum AutomationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  MANUAL_REQUIRED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  DROPDOWN
  TEXTAREA
}

// ─────────────────────────────────────
// MULTI-TENANT AGENCY MODEL
// ─────────────────────────────────────

model Agency {
  id              String    @id @default(uuid())
  name            String
  licenseNumber   String?   @unique
  address         String?
  phone           String?
  email           String    @unique
  logoUrl         String?
  plan            String    @default("FREE")  // FREE | STARTER | PRO | ENTERPRISE
  isActive        Boolean   @default(true)

  // Registration code (non-optional, 1-year expiry)
  registrationCodeId String?   @unique
  registrationCode   RegistrationCode? @relation(fields: [registrationCodeId], references: [id])

  // Limits
  candidateLimit  Int       @default(100)
  usersLimit      Int       @default(3)

  // Portal credentials (encrypted at application level)
  lmisCredentials         String?  // AES-256 encrypted JSON
  musanedSroCredentials   String?  // AES-256 encrypted JSON
  easyEnjazCredentials    String?  // AES-256 encrypted JSON
  mofaCredentials         String?  // AES-256 encrypted JSON
  wafidCredentials        String?  // AES-256 encrypted JSON
  tasheerCredentials      String?  // AES-256 encrypted JSON

  // Relations
  users           User[]
  applicants      Applicant[]
  customFields    CustomFieldDefinition[]
  excelTemplates  ExcelTemplate[]
  automationJobs  AutomationJob[]
  invites         AgencyInvite[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
}

// ─────────────────────────────────────
// REGISTRATION CODES (1-year expiry)
// ─────────────────────────────────────

model RegistrationCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?   // Optional note about which company this code is for
  isActive    Boolean   @default(true)
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  // Inverse relation: the agency that used this code
  agency     Agency?

  @@index([code])
  @@index([expiresAt])
}

// ─────────────────────────────────────
// USERS
// ─────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  agencyId        String
  agency          Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  email           String    @unique
  passwordHash    String
  name            String
  role            UserRole  @default(AGENT)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  avatarUrl       String?

  // NextAuth
  emailVerified   DateTime?
  sessions        Session[]
  accounts        Account[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agencyId])
  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model AgencyInvite {
  id         String   @id @default(uuid())
  agencyId   String
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  email      String
  role       UserRole @default(AGENT)
  token      String   @unique @default(uuid())
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────
// CORE APPLICANT MODEL
// ─────────────────────────────────────

model Applicant {
  id              String          @id @default(uuid())
  agencyId        String
  agency          Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Biographical (OCR-filled)
  passportNumber  String
  firstName       String
  middleName      String?
  lastName        String?
  fatherName      String?         // Father's name (Ethiopian naming convention)
  grandfatherName String?         // Grandfather's name
  firstNameAmh    String?         // Amharic first name
  middleNameAmh   String?         // Amharic middle name
  lastNameAmh     String?         // Amharic last name
  dateOfBirth     DateTime?
  placeOfBirth    String?
  dateOfIssue     DateTime?
  dateOfExpiry    DateTime?
  gender          Gender?
  nationality     String          @default("Ethiopian")
  issuingCountry  String          @default("Ethiopia")
  placeOfIssue    String?

  // Personal Details
  maritalStatus   MaritalStatus?
  childrenCount   Int             @default(0)
  religion        String?
  phone           String?
  emergencyContact String?
  livingTown      String?
  weight          Float?
  height          Float?

  // Professional Profile
  workPosition        String?         // Job position / occupation
  experienceYears     Int             @default(0)
  experienceCountries String[]        @default([])
  arabicLevel         LanguageLevel   @default(NONE)
  englishLevel        LanguageLevel   @default(NONE)
  educationLevel      EducationLevel  @default(NONE)
  monthlySalary       Float?
  contractPeriod      String?         // "2 years", "3 years"
  hasDrivingLicense   Boolean         @default(false)

  // Skills
  skillCleaning       Boolean         @default(false)
  skillCooking        Boolean         @default(false)
  skillArabicCooking  Boolean         @default(false)
  skillChildrenCare   Boolean         @default(false)
  skillBabySitting    Boolean         @default(false)
  skillElderCare      Boolean         @default(false)
  skillIroning        Boolean         @default(false)
  skillWashing        Boolean         @default(false)
  skillTutoring       Boolean         @default(false)
  skillDriving        Boolean         @default(false)
  skillGardening      Boolean         @default(false)

  // Pipeline Status
  status          ApplicantStatus @default(REGISTERED)
  statusHistory   StatusHistoryEntry[]

  // Document Asset URLs (Cloudinary secure URLs)
  passportPhotoUrl    String?
  passportScanUrl     String?
  fullBodyPhotoUrl    String?
  medicalReportUrl    String?
  cocCertificateUrl   String?
  cvUrl               String?

  // Medical Details
  medicalStatus       String?
  medicalCenter       String?
  medicalExpiryDate   DateTime?

  // Compliance Tracking
  lmisStatus          AutomationStatus?
  lmisReferenceNumber String?           // Reference number from LMIS portal
  lmisRegisteredAt    DateTime?
  musanedStatus       AutomationStatus?
  musanedContractNumber String?         // Contract number from Musaned portal
  musanedContractedAt DateTime?
  enjazReference      String?
  visaNumber          String?
  flightDate          DateTime?
  destinationCity     String?
  sponsorName         String?
  sponsorContact      String?

  // AI-Generated Notes
  agentNotes          String?         // Original unstructured notes
  parsedNotes         String?         // Cleaned AI version

  // OCR Metadata
  ocrConfidenceScore  Float?
  ocrProcessedAt      DateTime?

  // Dynamic Custom Fields
  customFields        Json            @default("{}")

  // Relations
  automationJobs      AutomationJob[]
  generatedExports    ExportRecord[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([agencyId, passportNumber])
  @@index([agencyId])
  @@index([status])
  @@index([passportNumber])
  @@index([dateOfExpiry])
  @@index([agencyId, status])
}

// ─────────────────────────────────────
// STATUS HISTORY
// ─────────────────────────────────────

model StatusHistoryEntry {
  id            String          @id @default(uuid())
  applicantId   String
  applicant     Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fromStatus    ApplicantStatus?
  toStatus      ApplicantStatus
  changedByName String?
  notes         String?
  timestamp     DateTime        @default(now())

  @@index([applicantId])
}

// ─────────────────────────────────────
// CUSTOM FIELD DEFINITIONS
// ─────────────────────────────────────

model CustomFieldDefinition {
  id          String    @id @default(uuid())
  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  fieldKey    String    // Stored as key in customFields JSON
  label       String    // Display name: "Has Vaccine Card"
  labelAmh    String?   // Amharic label
  fieldType   FieldType @default(TEXT)
  options     String[]  @default([])  // For DROPDOWN type
  isRequired  Boolean   @default(false)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([agencyId, fieldKey])
  @@index([agencyId])
}

// ─────────────────────────────────────
// AUTOMATION JOBS (Playwright Workers)
// ─────────────────────────────────────

model AutomationJob {
  id              String          @id @default(uuid())
  agencyId        String
  agency          Agency          @relation(fields: [agencyId], references: [id])
  applicantId     String
  applicant       Applicant       @relation(fields: [applicantId], references: [id])
  jobType         String          // Portal job type from src/lib/portals.ts
  status          AutomationStatus @default(PENDING)
  attempts        Int             @default(0)
  maxAttempts     Int             @default(3)
  resultData      Json?           // Tracking ID, contract ID, etc.
  errorMessage    String?
  screenshotUrl   String?         // Confirmation screenshot
  enqueuedAt      DateTime        @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  @@index([applicantId])
  @@index([agencyId, status])
  @@index([status])
}

// ─────────────────────────────────────
// EXCEL TEMPLATES & EXPORTS
// ─────────────────────────────────────

model ExcelTemplate {
  id            String    @id @default(uuid())
  agencyId      String
  agency        Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name          String    // "Saudi SRO Standard", "LMIS Format"
  description   String?
  columnMapping Json      // { "A": "firstName", "B": "lastName", ... }
  dateFormat    String    @default("DD/MM/YYYY")
  isDefault     Boolean   @default(false)
  isBuiltIn     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([agencyId])
}

model ExportRecord {
  id              String    @id @default(uuid())
  agencyId        String
  applicantId     String
  applicant       Applicant @relation(fields: [applicantId], references: [id])
  templateName    String
  fileUrl         String
  candidateCount  Int
  exportedByName  String?
  createdAt       DateTime  @default(now())

  @@index([agencyId])
}
