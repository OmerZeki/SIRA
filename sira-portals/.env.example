# ─── Application ──────────────────────────────────────────────────────────────
PORT=4000

# Secret that SIRA Next.js sends as "Authorization: Bearer <secret>"
# Set the same value in your Vercel env as PORTAL_SERVICE_SECRET
PORTAL_API_SECRET=change-me-to-a-strong-random-secret

# Allowed CORS origins (comma-separated)
SIRA_APP_ORIGIN=https://sira.qzz.io,http://localhost:3000

